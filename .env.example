# ===== AI (天机) config — server-side only =====
# ฝั่ง server เท่านั้น ห้ามใช้ NEXT_PUBLIC_ (apiKey จะ leak สู่ browser)
# ตั้งค่าจริงใน Vercel → Settings → Environment Variables หรือ .env.local

# API key ของ OpenAI-compatible endpoint (เช่น z.ai, OpenAI, Gemini-compat)
AI_API_KEY=

# Endpoint แบบเต็ม เช่น https://api.z.ai/api/coding/paas/v4/chat/completions
AI_ENDPOINT=

# ชื่อโมเดล เช่น glm-4.6, gpt-4o
AI_MODEL=

# (optional) 0-1, default 0.7
AI_TEMPERATURE=0.7
